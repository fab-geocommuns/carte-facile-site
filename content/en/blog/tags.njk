---js
{
  title: "Blog",
  pagination: {
    data: "collections.posts",
    size: 1,
    alias: "tag",
    before: function(paginationData, fullData) {
      // Filter by language
      const filtered = paginationData.filter(entry => entry.data.lang === fullData.lang);

      // Sort by date descending
      filtered.sort((a, b) => b.date - a.date);

      // Get unique tags
      const allTags = filtered.map(entry => entry.data.tags).flat();
      const excludeTags = ['all', 'nav', 'post', 'posts', 'events'];
      const uniqueTags = allTags.filter((tag, index, tags) =>
        tags.indexOf(tag) === index && !excludeTags.includes(tag)
      );

      // Paginate by tag
      const paginationSize = 10;
      let tagMap = [];
      uniqueTags.forEach(tag => {
        const tagEntries = filtered.filter(entry => entry.data.tags.includes(tag));
        const pageCount = Math.ceil(tagEntries.length / paginationSize);
        for (let i = 0; i < pageCount; i++) {
          tagMap.push({
            tagName: tag,
            pageNumber: i,
            pageData: tagEntries.slice(i * paginationSize, (i + 1) * paginationSize)
          });
        }
      });
      return tagMap;
    }
  },
  layout: "layouts/page.njk",
  permalink: "/{{ lang }}/blog/tags/{{ tag.tagName | slugify }}/{% if tag.pageNumber %}{{ pagePrefix }}{{ tag.pageNumber + 1 }}{% endif %}/",
}
---
<h2>{{ "filtered_by" | i18n }}
  <a class="fr-tag fr-fi-close-line fr-tag--icon-left" href="{{ "/blog/"| locale_url }}">
    {{ tag.tagName }}
  </a>
</h2>
<div class="fr-mt-6v fr-mb-6w">
  {% set tags = collections.posts | filterCollectionLang | getAllTags | filterTagList([tag.tagName]) %}
  {% include "components/taggroup.njk" %}
</div>
{% set postslist = tag.pageData %}
{% include "postslist.njk" %}
{% set tagUrl %}{{ "/blog/tags/"| locale_url }}{{ tag.tagName | slugify }}/{% endset %}
{% set pagination = pagination | buildPagination(tagUrl) %}
{% include "templates/pagination.njk" %}
